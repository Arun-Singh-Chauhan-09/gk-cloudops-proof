{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Retail Ops — POS Health & SLO",
  "uid": "retail-ops",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "POS Success Rate (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (pos:txn_failed:rate5m / clamp_min(pos:txn_total:rate5m, 1))",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "POS Transactions by Status (rate/s)",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(pos_transactions_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Budget Burn Rate (1h vs 6h)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "targets": [
        { "expr": "pos:error_ratio:rate1h", "legendFormat": "1h error ratio" },
        { "expr": "pos:error_ratio:rate6h", "legendFormat": "6h error ratio" },
        { "expr": "14.4 * 0.001", "legendFormat": "fast-burn threshold" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Store Sync Lag (seconds)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "store_sync_lag_seconds",
          "legendFormat": "store {{store_id}} ({{region}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sync Queue Backlog by Store",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "sync_queue_backlog",
          "legendFormat": "store {{store_id}}"
        }
      ]
    }
  ]
}
